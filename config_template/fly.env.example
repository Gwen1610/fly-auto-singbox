# Paths
PYTHON_BIN="python3"
SING_BOX_BIN="sing-box"
SUDO_BIN="sudo"
SINGBOX_RELEASES_API="https://api.github.com/repos/SagerNet/sing-box/releases"

# Pipeline files
EXTRACT_PROVIDERS_FILE="./config/extract.providers.json"
RULE_SOURCES_FILE="./config/rule-sources.json"
GROUP_STRATEGY_FILE="./config/group-strategy.json"
NODES_FILE="./build/nodes.json"
ROUTE_RULES_FILE="./config/route-rules.json"
# Used by `./fly build-rules --ruleset` / `./fly build-config --ruleset`.
ROUTE_RULES_FILE_RULESET="./config/route-rules.ruleset.json"
BASE_TEMPLATE_FILE="./config/base-template.json"
BASE_TEMPLATE_FILE_IOS="./config/base-template.ios.json"
BASE_TEMPLATE_FILE_TERMINAL="./config/base-template.json"
CONFIG_OUTPUT_DIR="./runtime-configs"
CONFIG_JSON="${CONFIG_OUTPUT_DIR}/config.json"
CONFIG_JSON_IOS="${CONFIG_OUTPUT_DIR}/config.ios.json"
CONFIG_JSON_TERMINAL="${CONFIG_OUTPUT_DIR}/config.terminal.json"
DESKTOP_PROFILE_DEFAULT="vt"
# Connectivity behavior for generated route defaults:
# - experience: keep DNS hijack + private IP direct, do not force QUIC reject
# - stable: also inject QUIC reject (protocol=quic / udp:443)
CONNECTIVITY_MODE="experience"
# urltest tuning (faster failover for region groups)
URLTEST_URL="https://www.gstatic.com/generate_204"
URLTEST_INTERVAL="5m"
URLTEST_TOLERANCE="50"

# Rule-set publish mode (optional)
# Used by `./fly build-rules --ruleset` (or `./fly build-ruleset`) to generate `.srs` under RULESET_DIR and reference them by URL in config.
RULESET_BASE_URL=""
RULESET_DIR="./ruleset"
# How generated config references rule-sets:
# - auto: desktop prefer local .srs if exists; iOS keep remote URL
# - remote: always keep URL-based remote rule-set
# - local: require local .srs for every rule-set tag (missing file = build error)
# - prefer-local: use local .srs when present, fallback to remote URL
RULESET_REFERENCE_MODE="auto"
RULESET_DOWNLOAD_DETOUR="Proxy"
RULESET_TAG_PREFIX="qx-"

# Runtime files
PID_FILE="./.sing-box.pid"
LOG_FILE="./sing-box.log"

# Manual install guide display version
SINGBOX_VERSION="1.12.20"
SINGBOX_INSTALL_DIR="/usr/local/bin"

# Clash API — used by fly select / fly delay / fly monitor
# Must match experimental.clash_api.external_controller in config/base-template.json
API_HOST="127.0.0.1:9090"
API_SECRET=""

# macOS DNS leak guard (terminal tun mode)
# When enabled, `./fly on` will temporarily set system DNS servers to the tun-side address(es) derived from the
# selected config (fail-closed), then restore them on `./fly off`. This helps prevent common DNS leak cases when
# the system DNS is a LAN/router IP.
MACOS_DNS_GUARD="true"
# When enabled, a root watchdog will restore DNS even if sing-box exits unexpectedly (crash/kill/terminal closed).
MACOS_DNS_GUARD_WATCHDOG="true"
