cmd_log() {
  load_env
  local lines="200"
  local follow="true"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n|--lines)
        shift
        [[ $# -gt 0 ]] || die "missing value for --lines"
        lines="$1"
        ;;
      --no-follow)
        follow="false"
        ;;
      *)
        die "unknown flag for log: $1"
