fly_tui_choose_on_config() {
  local search_dir="${1:-${CONFIG_OUTPUT_DIR:-$(pwd)}}"
  [[ -d "${search_dir}" ]] || return 1
  local -a files=()
  local -a display=()
  local -a selected_files=()
  local -a selected_syms=()

  while IFS= read -r entry; do
    [[ -n "${entry}" ]] || continue
    files+=("${search_dir}/${entry}")
    display+=("${entry}")
  done < <(find "${search_dir}" -maxdepth 1 -type f -name '*.json' -print | sed -E 's#^.*/##' | sort)

  if ((${#files[@]} == 0)); then
    return 1
  fi

  _fly_tui_title "fly on — 选择启动配置"
  local idx=0
  local shown=0
  while ((idx < ${#files[@]})); do
    local sym=""
    if ! sym="$(fly_tui_symbol_for_index "${shown}")"; then
      printf '  ...(文件过多，仅显示前 %d 个，可用 --config 指定其他文件)\n' "${shown}"
      break
    fi
    local label="${display[$idx]}"
    local meta=""
    case "${label}" in
      config.json) meta="桌面 VT 默认" ;;
      config.terminal.json) meta="桌面终端 1.12+" ;;
      config.ios.json) meta="iOS VT" ;;
    esac
    _fly_tui_option "${sym}" "${label}" "${meta}"
    selected_files+=("${files[$idx]}")
    selected_syms+=("${sym}")
    ((shown++))
    ((idx++))
