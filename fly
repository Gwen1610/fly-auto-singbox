#!/usr/bin/env bash
set -euo pipefail

FLY_VERSION="0.3.0"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="${ROOT_DIR}/config"
TEMPLATE_DIR="${ROOT_DIR}/config_template"
BUILD_DIR="${ROOT_DIR}/build"
SCRIPTS_DIR="${ROOT_DIR}/scripts"
ENV_FILE="${CONFIG_DIR}/fly.env"
ENV_EXAMPLE_FILE="${TEMPLATE_DIR}/fly.env.example"
PROVIDERS_FILE="${CONFIG_DIR}/extract.providers.json"
PROVIDERS_EXAMPLE_FILE="${TEMPLATE_DIR}/extract.providers.example.json"
RULE_SOURCES_FILE_DEFAULT="${CONFIG_DIR}/rule-sources.json"
RULE_SOURCES_EXAMPLE_FILE="${TEMPLATE_DIR}/rule-sources.example.json"
GROUP_STRATEGY_FILE_DEFAULT="${CONFIG_DIR}/group-strategy.json"
GROUP_STRATEGY_EXAMPLE_FILE="${TEMPLATE_DIR}/group-strategy.example.json"
ROUTE_RULES_FILE_DEFAULT="${CONFIG_DIR}/route-rules.json"
ROUTE_RULES_EXAMPLE_FILE="${TEMPLATE_DIR}/route-rules.example.json"

COLOR_RESET=$'\033[0m'
COLOR_BLUE=$'\033[34m'
COLOR_GREEN=$'\033[32m'
COLOR_YELLOW=$'\033[33m'
COLOR_RED=$'\033[31m'
COLOR_CYAN=$'\033[36m'
COLOR_STDOUT_ENABLED="0"
COLOR_STDERR_ENABLED="0"

if [[ -z "${NO_COLOR:-}" ]] && [[ "${TERM:-}" != "dumb" ]]; then
  if [[ -t 1 ]]; then
    COLOR_STDOUT_ENABLED="1"
  fi
  if [[ -t 2 ]]; then
    COLOR_STDERR_ENABLED="1"
  fi
fi

stdout_line() {
  local color="$1"
  local text="$2"
  if [[ "${COLOR_STDOUT_ENABLED}" == "1" ]]; then
    printf '%b%s%b\n' "${color}" "${text}" "${COLOR_RESET}"
  else
    printf '%s\n' "${text}"
  fi
}

stderr_line() {
  local color="$1"
  local text="$2"
  if [[ "${COLOR_STDERR_ENABLED}" == "1" ]]; then
    printf '%b%s%b\n' "${color}" "${text}" "${COLOR_RESET}" >&2
  else
    printf '%s\n' "${text}" >&2
  fi
}

log() {
  if [[ "${COLOR_STDOUT_ENABLED}" == "1" ]]; then
    printf '%b[fly]%b %s\n' "${COLOR_BLUE}" "${COLOR_RESET}" "$*"
  else
    printf '[fly] %s\n' "$*"
  fi
}

warn() {
  if [[ "${COLOR_STDERR_ENABLED}" == "1" ]]; then
    printf '%b[fly][warn]%b %s\n' "${COLOR_YELLOW}" "${COLOR_RESET}" "$*" >&2
  else
    printf '[fly][warn] %s\n' "$*" >&2
  fi
}

die() {
  if [[ "${COLOR_STDERR_ENABLED}" == "1" ]]; then
    printf '%b[fly][error]%b %s\n' "${COLOR_RED}" "${COLOR_RESET}" "$*" >&2
  else
    printf '[fly][error] %s\n' "$*" >&2
  fi
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

abs_path() {
  local path="$1"
  if [[ "${path}" = /* ]]; then
    printf '%s\n' "${path}"
  else
    printf '%s\n' "${ROOT_DIR}/${path#./}"
  fi
}

usage() {
  cat <<'EOF'
Fly - decoupled sing-box pipeline

Usage:
  ./fly init [--force]
  ./fly check-singbox
  ./fly install-singbox [--version v] [--os linux|darwin] [--arch amd64|arm64] [--install-dir dir] [--dry-run] [--force]
  ./fly install-guide
  ./fly build-rules [--ruleset] [--compact] [--base-url url] [--ruleset-dir dir] [--skip-compile]
  ./fly build-ruleset [--base-url url] [--ruleset-dir dir] [--skip-compile]  # alias of build-rules --ruleset
  ./fly publish-ruleset [--message msg] [--dry-run]
  ./fly extract
  ./fly build-config [--target desktop|ios] [--ruleset] [--compact]
  ./fly pipeline [--target desktop|ios] [--ruleset] [--compact]
  ./fly on
  ./fly off
  ./fly status
  ./fly log [-n lines] [--no-follow]
  ./fly help

Command summary:
  init          Create local runtime config files from templates
  check-singbox Show installed sing-box path and version
  install-singbox Auto download + install sing-box for linux/mac
  install-guide  Alias of install-singbox --dry-run
  build-rules   Build route rules from QX/Clash sources (inline by default; use --ruleset for rule-set mode)
  build-ruleset Alias of build-rules --ruleset (kept for backward compatibility)
  publish-ruleset Stage/commit/push ruleset/ to GitHub
  extract       Extract region nodes only (US/HK/SG/JP, no route rules)
  build-config  Build final config.json by injecting route rules into extracted nodes
  pipeline      Run extract + build-config (or --ruleset: extract + build-rules --ruleset + build-config --ruleset)
  on            Start sing-box in background (nohup + PID file)
  off           Stop sing-box using PID file (with pkill fallback)
  status        Show running status from PID file
  log           Tail sing-box log file
  help          Show this help
EOF
}

backup_existing_file() {
  local file="$1"
  [[ -f "${file}" ]] || return 0
  mkdir -p "${BUILD_DIR}/backup"
  local backup_file="${BUILD_DIR}/backup/$(basename "${file}").bak.$(date +%Y%m%d%H%M%S)"
  cp "${file}" "${backup_file}"
  log "backup ${file} -> ${backup_file}"
}

load_env() {
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck disable=SC1090
    source "${ENV_FILE}"
  else
    warn "missing ${ENV_FILE}; using built-in defaults (run ./fly init to generate files)"
  fi

  : "${PYTHON_BIN:=python3}"
  : "${SING_BOX_BIN:=sing-box}"
  if [[ -z "${SUDO_BIN+x}" ]]; then
    SUDO_BIN="sudo"
  fi
  : "${EXTRACT_PROVIDERS_FILE:=./config/extract.providers.json}"
  : "${RULE_SOURCES_FILE:=./config/rule-sources.json}"
  : "${GROUP_STRATEGY_FILE:=./config/group-strategy.json}"
  : "${NODES_FILE:=./build/nodes.json}"
  : "${ROUTE_RULES_FILE:=./config/route-rules.json}"
  : "${ROUTE_RULES_FILE_ONLINE:=}"
  : "${ROUTE_RULES_FILE_RULESET:=${ROUTE_RULES_FILE_ONLINE:-./config/route-rules.ruleset.json}}"
  : "${BASE_TEMPLATE_FILE:=./config/base-template.json}"
  : "${BASE_TEMPLATE_FILE_IOS:=./config/base-template.ios.json}"
  : "${CONFIG_JSON:=./config.json}"
  : "${CONFIG_JSON_IOS:=./config.ios.json}"
  : "${RULESET_BASE_URL:=}"
  : "${RULESET_DIR:=./ruleset}"
  : "${RULESET_DOWNLOAD_DETOUR:=Proxy}"
  : "${RULESET_TAG_PREFIX:=qx-}"
  : "${PID_FILE:=./.sing-box.pid}"
  : "${LOG_FILE:=./sing-box.log}"
  : "${SINGBOX_VERSION:=1.12.20}"
  : "${SINGBOX_INSTALL_DIR:=/usr/local/bin}"
  : "${SINGBOX_RELEASES_API:=https://api.github.com/repos/SagerNet/sing-box/releases}"

  EXTRACT_PROVIDERS_FILE="$(abs_path "${EXTRACT_PROVIDERS_FILE}")"
  RULE_SOURCES_FILE="$(abs_path "${RULE_SOURCES_FILE}")"
  GROUP_STRATEGY_FILE="$(abs_path "${GROUP_STRATEGY_FILE}")"
  NODES_FILE="$(abs_path "${NODES_FILE}")"
  ROUTE_RULES_FILE="$(abs_path "${ROUTE_RULES_FILE}")"
  ROUTE_RULES_FILE_RULESET="$(abs_path "${ROUTE_RULES_FILE_RULESET}")"
  BASE_TEMPLATE_FILE="$(abs_path "${BASE_TEMPLATE_FILE}")"
  BASE_TEMPLATE_FILE_IOS="$(abs_path "${BASE_TEMPLATE_FILE_IOS}")"
  CONFIG_JSON="$(abs_path "${CONFIG_JSON}")"
  CONFIG_JSON_IOS="$(abs_path "${CONFIG_JSON_IOS}")"
  RULESET_DIR="$(abs_path "${RULESET_DIR}")"
  PID_FILE="$(abs_path "${PID_FILE}")"
  LOG_FILE="$(abs_path "${LOG_FILE}")"
}

detect_os() {
  case "$(uname -s)" in
    Linux) printf 'linux\n' ;;
    Darwin) printf 'darwin\n' ;;
    *) die "unsupported OS: $(uname -s)" ;;
  esac
}

detect_arch() {
  case "$(uname -m)" in
    x86_64|amd64) printf 'amd64\n' ;;
    aarch64|arm64) printf 'arm64\n' ;;
    *) die "unsupported architecture: $(uname -m)" ;;
  esac
}

guess_ruleset_base_url_from_git() {
  command -v git >/dev/null 2>&1 || return 1

  local origin=""
  origin="$(git config --get remote.origin.url 2>/dev/null || true)"
  [[ -n "${origin}" ]] || return 1

  local path=""
  case "${origin}" in
    git@github.com:*) path="${origin#git@github.com:}" ;;
    ssh://git@github.com/*) path="${origin#ssh://git@github.com/}" ;;
    https://github.com/*) path="${origin#https://github.com/}" ;;
    http://github.com/*) path="${origin#http://github.com/}" ;;
    *) return 1 ;;
  esac
  path="${path%.git}"

  local owner="" repo=""
  IFS='/' read -r owner repo _rest <<<"${path}"
  [[ -n "${owner}" && -n "${repo}" ]] || return 1

  local branch="main"
  local head=""
  head="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if [[ -n "${head}" && "${head}" != "HEAD" ]]; then
    branch="${head}"
  fi

  printf 'https://raw.githubusercontent.com/%s/%s/%s/ruleset\n' "${owner}" "${repo}" "${branch}"
}

resolve_release_asset() {
  local version="$1"
  local target_os="$2"
  local target_arch="$3"
  local releases_file="$4"
  python3 - "${version}" "${target_os}" "${target_arch}" "${releases_file}" <<'PY'
import json
import sys
from pathlib import Path

version = sys.argv[1]
target_os = sys.argv[2]
target_arch = sys.argv[3]
releases = json.loads(Path(sys.argv[4]).read_text(encoding="utf-8"))

if not isinstance(releases, list):
    raise SystemExit("unexpected releases API response")

target_release = None
if version == "latest":
    for rel in releases:
        if not rel.get("prerelease"):
            target_release = rel
            break
else:
    wanted = version.lstrip("v")
    for rel in releases:
        tag = str(rel.get("tag_name", "")).lstrip("v")
        if tag == wanted:
            target_release = rel
            break

if not target_release:
    raise SystemExit(f"cannot find release for version: {version}")

asset_url = ""
asset_name = ""
needle = f"{target_os}-{target_arch}"
for asset in target_release.get("assets", []):
    name = str(asset.get("name", ""))
    if needle in name and name.endswith(".tar.gz"):
        asset_name = name
        asset_url = str(asset.get("browser_download_url", ""))
        break

if not asset_url:
    raise SystemExit(f"no {needle} .tar.gz asset found in {target_release.get('tag_name')}")

print(str(target_release.get("tag_name", "")))
print(asset_name)
print(asset_url)
PY
}

normalize_version() {
  local raw="$1"
  raw="${raw#v}"
  printf '%s' "${raw}" | sed -E 's/^[^0-9]*([0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9]+)?)?.*$/\1/'
}

resolve_singbox_binary_path() {
  local configured="${SING_BOX_BIN}"
  local resolved=""
  if [[ "${configured}" == */* ]]; then
    resolved="$(abs_path "${configured}")"
    if [[ -x "${resolved}" ]]; then
      printf '%s\n' "${resolved}"
      return 0
    fi
  else
    resolved="$(command -v "${configured}" 2>/dev/null || true)"
    if [[ -n "${resolved}" ]]; then
      printf '%s\n' "${resolved}"
      return 0
    fi
  fi

  if [[ "${configured}" != "sing-box" ]]; then
    resolved="$(command -v sing-box 2>/dev/null || true)"
    if [[ -n "${resolved}" ]]; then
      printf '%s\n' "${resolved}"
      return 0
    fi
  fi

  resolved="${SINGBOX_INSTALL_DIR%/}/sing-box"
  if [[ -x "${resolved}" ]]; then
    printf '%s\n' "${resolved}"
    return 0
  fi
  return 1
}

get_singbox_installed_info() {
  local path=""
  path="$(resolve_singbox_binary_path || true)"
  if [[ -z "${path}" ]]; then
    return 1
  fi
  local ver_line=""
  ver_line="$("${path}" version 2>/dev/null | head -n 1 || true)"
  local norm_ver=""
  norm_ver="$(normalize_version "${ver_line}")"
  printf '%s\n' "${path}"
  printf '%s\n' "${ver_line}"
  printf '%s\n' "${norm_ver}"
}

run_as_sudo() {
  if [[ -n "${SUDO_BIN}" ]]; then
    "${SUDO_BIN}" "$@"
  else
    "$@"
  fi
}

ensure_sudo_ticket() {
  if [[ -n "${SUDO_BIN}" ]]; then
    "${SUDO_BIN}" -v
  fi
}

pid_is_alive() {
  local pid="$1"
  [[ "${pid}" =~ ^[0-9]+$ ]] || return 1
  if [[ -n "${SUDO_BIN}" ]]; then
    "${SUDO_BIN}" kill -0 "${pid}" >/dev/null 2>&1
  else
    kill -0 "${pid}" >/dev/null 2>&1
  fi
}

read_pid_file() {
  [[ -f "${PID_FILE}" ]] || return 1
  local pid
  pid="$(cat "${PID_FILE}" 2>/dev/null || true)"
  [[ "${pid}" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "${pid}"
}

init_files() {
  local force="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force|-f) force="true" ;;
      *) die "unknown flag for init: $1" ;;
    esac
    shift
  done

  mkdir -p "${CONFIG_DIR}" "${BUILD_DIR}" "${SCRIPTS_DIR}"

  if [[ ! -f "${ENV_EXAMPLE_FILE}" ]]; then
    die "missing template: ${ENV_EXAMPLE_FILE}"
  fi
  if [[ ! -f "${PROVIDERS_EXAMPLE_FILE}" ]]; then
    die "missing template: ${PROVIDERS_EXAMPLE_FILE}"
  fi
  if [[ ! -f "${RULE_SOURCES_EXAMPLE_FILE}" ]]; then
    die "missing template: ${RULE_SOURCES_EXAMPLE_FILE}"
  fi
  if [[ ! -f "${GROUP_STRATEGY_EXAMPLE_FILE}" ]]; then
    die "missing template: ${GROUP_STRATEGY_EXAMPLE_FILE}"
  fi
  if [[ ! -f "${ROUTE_RULES_EXAMPLE_FILE}" ]]; then
    die "missing template: ${ROUTE_RULES_EXAMPLE_FILE}"
  fi

  if [[ ! -f "${ENV_FILE}" ]] || is_true "${force}"; then
    if [[ -f "${ENV_FILE}" ]]; then
      backup_existing_file "${ENV_FILE}"
    fi
    cp "${ENV_EXAMPLE_FILE}" "${ENV_FILE}"
    log "generated ${ENV_FILE}"
  else
    log "exists ${ENV_FILE}, skip"
  fi

  if [[ ! -f "${PROVIDERS_FILE}" ]] || is_true "${force}"; then
    if [[ -f "${PROVIDERS_FILE}" ]]; then
      backup_existing_file "${PROVIDERS_FILE}"
    fi
    cp "${PROVIDERS_EXAMPLE_FILE}" "${PROVIDERS_FILE}"
    log "generated ${PROVIDERS_FILE}"
  else
    log "exists ${PROVIDERS_FILE}, skip"
  fi

  if [[ ! -f "${RULE_SOURCES_FILE_DEFAULT}" ]] || is_true "${force}"; then
    if [[ -f "${RULE_SOURCES_FILE_DEFAULT}" ]]; then
      backup_existing_file "${RULE_SOURCES_FILE_DEFAULT}"
    fi
    cp "${RULE_SOURCES_EXAMPLE_FILE}" "${RULE_SOURCES_FILE_DEFAULT}"
    log "generated ${RULE_SOURCES_FILE_DEFAULT}"
  else
    log "exists ${RULE_SOURCES_FILE_DEFAULT}, skip"
  fi

  if [[ ! -f "${GROUP_STRATEGY_FILE_DEFAULT}" ]] || is_true "${force}"; then
    if [[ -f "${GROUP_STRATEGY_FILE_DEFAULT}" ]]; then
      backup_existing_file "${GROUP_STRATEGY_FILE_DEFAULT}"
    fi
    cp "${GROUP_STRATEGY_EXAMPLE_FILE}" "${GROUP_STRATEGY_FILE_DEFAULT}"
    log "generated ${GROUP_STRATEGY_FILE_DEFAULT}"
  else
    log "exists ${GROUP_STRATEGY_FILE_DEFAULT}, skip"
  fi

  if [[ ! -f "${ROUTE_RULES_FILE_DEFAULT}" ]] || is_true "${force}"; then
    if [[ -f "${ROUTE_RULES_FILE_DEFAULT}" ]]; then
      backup_existing_file "${ROUTE_RULES_FILE_DEFAULT}"
    fi
    cp "${ROUTE_RULES_EXAMPLE_FILE}" "${ROUTE_RULES_FILE_DEFAULT}"
    log "generated ${ROUTE_RULES_FILE_DEFAULT}"
  else
    log "exists ${ROUTE_RULES_FILE_DEFAULT}, skip"
  fi

  log "init complete"
}

cmd_install_singbox() {
  load_env
  local version="${SINGBOX_VERSION}"
  local target_os=""
  local target_arch=""
  local install_dir="${SINGBOX_INSTALL_DIR}"
  local dry_run="false"
  local force_install="false"
  local releases_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --version)
        shift
        [[ $# -gt 0 ]] || die "missing value for --version"
        version="$1"
        ;;
      --os)
        shift
        [[ $# -gt 0 ]] || die "missing value for --os"
        target_os="$1"
        ;;
      --arch)
        shift
        [[ $# -gt 0 ]] || die "missing value for --arch"
        target_arch="$1"
        ;;
      --install-dir)
        shift
        [[ $# -gt 0 ]] || die "missing value for --install-dir"
        install_dir="$1"
        ;;
      --dry-run)
        dry_run="true"
        ;;
      --force)
        force_install="true"
        ;;
      --releases-json)
        shift
        [[ $# -gt 0 ]] || die "missing value for --releases-json"
        releases_file="$(abs_path "$1")"
        ;;
      *)
        die "unknown flag for install-singbox: $1"
        ;;
    esac
    shift
  done

  [[ -n "${target_os}" ]] || target_os="$(detect_os)"
  [[ -n "${target_arch}" ]] || target_arch="$(detect_arch)"
  [[ "${target_os}" =~ ^(linux|darwin)$ ]] || die "unsupported --os: ${target_os}"
  [[ "${target_arch}" =~ ^(amd64|arm64)$ ]] || die "unsupported --arch: ${target_arch}"

  local tmp_dir
  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "${tmp_dir:-}"' RETURN

  if [[ -z "${releases_file}" ]]; then
    need_cmd curl
    releases_file="${tmp_dir}/releases.json"
    curl -fsSL "${SINGBOX_RELEASES_API}" -o "${releases_file}"
  else
    [[ -f "${releases_file}" ]] || die "missing releases JSON file: ${releases_file}"
  fi

  local release_meta release_tag asset_name asset_url
  release_meta="$(resolve_release_asset "${version}" "${target_os}" "${target_arch}" "${releases_file}")"
  release_tag="$(printf '%s\n' "${release_meta}" | sed -n '1p')"
  asset_name="$(printf '%s\n' "${release_meta}" | sed -n '2p')"
  asset_url="$(printf '%s\n' "${release_meta}" | sed -n '3p')"

  local installed_path="" installed_line="" installed_norm=""
  local info=""
  info="$(get_singbox_installed_info || true)"
  if [[ -n "${info}" ]]; then
    installed_path="$(printf '%s\n' "${info}" | sed -n '1p')"
    installed_line="$(printf '%s\n' "${info}" | sed -n '2p')"
    installed_norm="$(printf '%s\n' "${info}" | sed -n '3p')"
  fi
  local release_norm
  release_norm="$(normalize_version "${release_tag}")"
  local will_skip="false"
  if [[ -n "${installed_norm}" ]] && [[ "${installed_norm}" == "${release_norm}" ]] && ! is_true "${force_install}"; then
    will_skip="true"
  fi

  if is_true "${dry_run}"; then
    cat <<EOF
[dry-run] sing-box install plan
release_tag=${release_tag}
asset=${asset_name}
url=${asset_url}
install_dir=${install_dir}
sudo=${SUDO_BIN:-<none>}
installed_path=${installed_path:-<none>}
installed_version=${installed_norm:-<unknown>}
will_skip=${will_skip}
EOF
    trap - RETURN
    rm -rf "${tmp_dir}"
    return 0
  fi

  if is_true "${will_skip}"; then
    log "sing-box already installed: ${installed_path} (${installed_norm}), skip download (use --force to reinstall)"
    trap - RETURN
    rm -rf "${tmp_dir}"
    return 0
  fi

  need_cmd curl
  need_cmd tar
  need_cmd install

  local tarball="${tmp_dir}/sing-box.tar.gz"
  log "downloading ${asset_name}"
  curl -fsSL "${asset_url}" -o "${tarball}"
  tar -xzf "${tarball}" -C "${tmp_dir}"

  local binary_path
  binary_path="$(find "${tmp_dir}" -type f -name sing-box | head -n 1 || true)"
  [[ -n "${binary_path}" ]] || die "cannot find sing-box binary in downloaded archive"

  if [[ -n "${SUDO_BIN}" ]]; then
    "${SUDO_BIN}" install -d "${install_dir}"
    "${SUDO_BIN}" install -m 755 "${binary_path}" "${install_dir}/sing-box"
  else
    install -d "${install_dir}"
    install -m 755 "${binary_path}" "${install_dir}/sing-box"
  fi

  log "installed sing-box -> ${install_dir}/sing-box"
  "${install_dir}/sing-box" version || true
  trap - RETURN
  rm -rf "${tmp_dir}"
}

cmd_check_singbox() {
  load_env
  local info=""
  info="$(get_singbox_installed_info || true)"
  if [[ -z "${info}" ]]; then
    printf 'not installed\n'
    return 0
  fi
  local installed_path installed_line installed_norm
  installed_path="$(printf '%s\n' "${info}" | sed -n '1p')"
  installed_line="$(printf '%s\n' "${info}" | sed -n '2p')"
  installed_norm="$(printf '%s\n' "${info}" | sed -n '3p')"
  printf 'installed_path=%s\n' "${installed_path}"
  printf 'version_line=%s\n' "${installed_line:-<unknown>}"
  printf 'version=%s\n' "${installed_norm:-<unknown>}"
}

cmd_install_guide() {
  cmd_install_singbox --dry-run "$@"
}

cmd_extract() {
  load_env
  need_cmd "${PYTHON_BIN}"
  [[ -f "${EXTRACT_PROVIDERS_FILE}" ]] || die "missing providers config: ${EXTRACT_PROVIDERS_FILE}"

  mkdir -p "$(dirname "${NODES_FILE}")"
  "${PYTHON_BIN}" "${SCRIPTS_DIR}/extract_nodes.py" \
    --providers-file "${EXTRACT_PROVIDERS_FILE}" \
    --output-file "${NODES_FILE}"
  log "extracted nodes -> ${NODES_FILE}"
}

cmd_build_rules() {
  load_env
  need_cmd "${PYTHON_BIN}"
  [[ -f "${RULE_SOURCES_FILE}" ]] || die "missing rule sources config: ${RULE_SOURCES_FILE}"

  local ruleset="false"
  local base_url="${RULESET_BASE_URL}"
  local ruleset_dir="${RULESET_DIR}"
  local skip_compile="false"
  local compact="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ruleset)
        ruleset="true"
        ;;
      --online)
        warn "--online is deprecated; use --ruleset"
        ruleset="true"
        ;;
      --base-url)
        shift
        [[ $# -gt 0 ]] || die "missing value for --base-url"
        base_url="$1"
        ;;
      --ruleset-dir)
        shift
        [[ $# -gt 0 ]] || die "missing value for --ruleset-dir"
        ruleset_dir="$1"
        ;;
      --skip-compile)
        skip_compile="true"
        ;;
      --compact)
        compact="true"
        ;;
      *)
        die "unknown flag for build-rules: $1"
        ;;
    esac
    shift
  done

  if is_true "${ruleset}"; then
    if [[ -z "${base_url}" ]]; then
      base_url="$(guess_ruleset_base_url_from_git || true)"
    fi
    [[ -n "${base_url}" ]] || die "RULESET_BASE_URL is empty (or pass --base-url) for --ruleset"

    mkdir -p "$(dirname "${ROUTE_RULES_FILE_RULESET}")" "${ruleset_dir}"
    local -a extra_args=()
    if is_true "${skip_compile}"; then
      extra_args+=(--skip-compile)
    fi

    local -a cmd=(
      "${PYTHON_BIN}" "${SCRIPTS_DIR}/build_route_rules.py"
      --sources-file "${RULE_SOURCES_FILE}"
      --output-file "${ROUTE_RULES_FILE_RULESET}"
      --mode ruleset
      --ruleset-dir "${ruleset_dir}"
      --ruleset-base-url "${base_url}"
      --ruleset-download-detour "${RULESET_DOWNLOAD_DETOUR}"
      --ruleset-tag-prefix "${RULESET_TAG_PREFIX}"
      --sing-box-bin "${SING_BOX_BIN}"
    )
    if is_true "${compact}"; then
      cmd+=(--compact)
    fi
    # NOTE: macOS default bash is 3.2. With `set -u`, expanding an empty array
    # like "${extra_args[@]}" will raise "unbound variable". Guard it.
    if ((${#extra_args[@]})); then
      cmd+=("${extra_args[@]}")
    fi
    "${cmd[@]}"
    log "generated ruleset route rules -> ${ROUTE_RULES_FILE_RULESET}"
    log "generated rule-set files -> ${ruleset_dir}"
    log "ruleset base url -> ${base_url}"
    return 0
  fi

  mkdir -p "$(dirname "${ROUTE_RULES_FILE}")"
  local -a cmd=(
    "${PYTHON_BIN}" "${SCRIPTS_DIR}/build_route_rules.py"
    --sources-file "${RULE_SOURCES_FILE}"
    --output-file "${ROUTE_RULES_FILE}"
  )
  if is_true "${compact}"; then
    cmd+=(--compact)
  fi
  "${cmd[@]}"
  log "generated route rules -> ${ROUTE_RULES_FILE}"
}

cmd_build_ruleset() {
  # Backward compatible alias. Prefer: ./fly build-rules --ruleset ...
  cmd_build_rules --ruleset "$@"
}

cmd_build_config() {
  load_env
  need_cmd "${PYTHON_BIN}"
  local ruleset="false"
  local target="desktop"
  local compact="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ruleset)
        ruleset="true"
        ;;
      --online)
        warn "--online is deprecated; use --ruleset"
        ruleset="true"
        ;;
      --target)
        shift
        [[ $# -gt 0 ]] || die "missing value for --target"
        target="$1"
        ;;
      --compact)
        compact="true"
        ;;
      *)
        die "unknown flag for build-config: $1"
        ;;
    esac
    shift
  done

  [[ "${target}" =~ ^(desktop|ios)$ ]] || die "unsupported --target: ${target} (use desktop|ios)"

  local rules_file="${ROUTE_RULES_FILE}"
  if is_true "${ruleset}"; then
    rules_file="${ROUTE_RULES_FILE_RULESET}"
  fi
  local template_file="${BASE_TEMPLATE_FILE}"
  local output_file="${CONFIG_JSON}"
  if [[ "${target}" == "ios" ]]; then
    template_file="${BASE_TEMPLATE_FILE_IOS}"
    output_file="${CONFIG_JSON_IOS}"
  fi

  [[ -f "${NODES_FILE}" ]] || die "missing nodes file: ${NODES_FILE} (run ./fly extract first)"
  [[ -f "${rules_file}" ]] || die "missing route rules file: ${rules_file}"
  [[ -f "${GROUP_STRATEGY_FILE}" ]] || die "missing group strategy file: ${GROUP_STRATEGY_FILE}"
  [[ -f "${template_file}" ]] || die "missing base template: ${template_file}"

  local -a cmd=(
    "${PYTHON_BIN}" "${SCRIPTS_DIR}/build_config.py"
    --nodes-file "${NODES_FILE}"
    --rules-file "${rules_file}"
    --groups-file "${GROUP_STRATEGY_FILE}"
    --template-file "${template_file}"
    --output-file "${output_file}"
    --target "${target}"
  )
  if is_true "${compact}"; then
    cmd+=(--compact)
  fi
  "${cmd[@]}"
  log "generated config -> ${output_file}"
}

cmd_publish_ruleset() {
  load_env
  need_cmd git

  local message="chore: publish ruleset"
  local dry_run="false"
  local remote="origin"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --message)
        shift
        [[ $# -gt 0 ]] || die "missing value for --message"
        message="$1"
        ;;
      --dry-run)
        dry_run="true"
        ;;
      --remote)
        shift
        [[ $# -gt 0 ]] || die "missing value for --remote"
        remote="$1"
        ;;
      *)
        die "unknown flag for publish-ruleset: $1"
        ;;
    esac
    shift
  done

  mkdir -p "${RULESET_DIR}"
  git add -A -- "${RULESET_DIR}" >/dev/null 2>&1 || die "git add failed for ${RULESET_DIR}"

  local staged_changes="false"
  if ! git diff --cached --quiet; then
    staged_changes="true"
  fi

  local branch=""
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  [[ -n "${branch}" ]] || branch="main"

  local upstream=""
  upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null || true)"
  local ahead="0"
  if [[ -n "${upstream}" ]]; then
    ahead="$(git rev-list --count "${upstream}..HEAD" 2>/dev/null || echo 0)"
  fi

  printf 'dry_run=%s\n' "${dry_run}"
  printf 'ruleset_dir=%s\n' "${RULESET_DIR}"
  printf 'staged_changes=%s\n' "${staged_changes}"
  printf 'branch=%s\n' "${branch}"
  printf 'upstream=%s\n' "${upstream:-<none>}"
  printf 'ahead=%s\n' "${ahead}"

  if is_true "${dry_run}"; then
    if [[ "${staged_changes}" == "true" ]]; then
      git diff --cached --stat || true
    fi
    if [[ "${staged_changes}" == "true" || "${ahead}" != "0" ]]; then
      printf 'result=would commit/push\n'
    else
      printf 'result=no changes\n'
    fi
    return 0
  fi

  if [[ "${staged_changes}" == "true" ]]; then
    git commit -m "${message}" || die "git commit failed"
  fi

  if [[ "${staged_changes}" != "true" && "${ahead}" == "0" ]]; then
    printf 'result=no changes\n'
    return 0
  fi

  local push_out=""
  if push_out="$(git push "${remote}" "${branch}" 2>&1)"; then
    printf 'result=published\n'
    return 0
  fi

  # Common macOS / proxy / HTTP2 issue: GitHub may reset the connection and report HTTP 400.
  if printf '%s\n' "${push_out}" | grep -qE 'RPC failed; HTTP 400|curl 22|unexpected disconnect|remote end hung up unexpectedly'; then
    warn "git push failed with HTTP 400 / disconnect; retry with http.version=HTTP/1.1 and larger postBuffer"
    git config http.version HTTP/1.1 || true
    git config http.postBuffer 524288000 || true
    git config core.compression 0 || true
    if push_out="$(git push "${remote}" "${branch}" 2>&1)"; then
      printf 'result=published\n'
      return 0
    fi
  fi

  printf '%s\n' "${push_out}" >&2
  die "git push failed"
}

cmd_pipeline() {
  local ruleset="false"
  local target="desktop"
  local compact="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ruleset)
        ruleset="true"
        ;;
      --online)
        warn "--online is deprecated; use --ruleset"
        ruleset="true"
        ;;
      --target)
        shift
        [[ $# -gt 0 ]] || die "missing value for --target"
        target="$1"
        ;;
      --compact)
        compact="true"
        ;;
      *)
        die "unknown flag for pipeline: $1"
        ;;
    esac
    shift
  done

  cmd_extract
  if is_true "${ruleset}"; then
    if is_true "${compact}"; then
      cmd_build_rules --ruleset --compact
      cmd_build_config --ruleset --target "${target}" --compact
    else
      cmd_build_rules --ruleset
      cmd_build_config --ruleset --target "${target}"
    fi
  else
    if is_true "${compact}"; then
      cmd_build_config --target "${target}" --compact
    else
      cmd_build_config --target "${target}"
    fi
  fi
}

cmd_on() {
  load_env
  [[ -f "${CONFIG_JSON}" ]] || die "missing ${CONFIG_JSON}; run ./fly build-config first"
  need_cmd nohup
  need_cmd "${SING_BOX_BIN}"

  local old_pid=""
  if old_pid="$(read_pid_file)" && pid_is_alive "${old_pid}"; then
    stdout_line "${COLOR_YELLOW}" "already running (pid: ${old_pid})"
    return 0
  fi

  ensure_sudo_ticket
  mkdir -p "$(dirname "${PID_FILE}")" "$(dirname "${LOG_FILE}")"

  local start_cmd
  printf -v start_cmd 'nohup %q run -c %q > %q 2>&1 & echo $! > %q' \
    "${SING_BOX_BIN}" "${CONFIG_JSON}" "${LOG_FILE}" "${PID_FILE}"

  if [[ -n "${SUDO_BIN}" ]]; then
    "${SUDO_BIN}" sh -c "${start_cmd}"
  else
    sh -c "${start_cmd}"
  fi

  sleep 1
  local new_pid
  new_pid="$(read_pid_file || true)"
  [[ -n "${new_pid}" ]] || die "failed to write PID file: ${PID_FILE}"
  if ! pid_is_alive "${new_pid}"; then
    die "process failed to start (pid=${new_pid}); check ${LOG_FILE}"
  fi
  stdout_line "${COLOR_GREEN}" "started (pid: ${new_pid})"
  stdout_line "${COLOR_CYAN}" "log: ${LOG_FILE}"
}

cmd_off() {
  load_env
  local stopped="false"
  local pid=""

  if pid="$(read_pid_file)" && pid_is_alive "${pid}"; then
    run_as_sudo kill "${pid}" >/dev/null 2>&1 || true
    local _i
    for _i in 1 2 3 4 5; do
      if ! pid_is_alive "${pid}"; then
        break
      fi
      sleep 1
    done
    if pid_is_alive "${pid}"; then
      run_as_sudo kill -9 "${pid}" >/dev/null 2>&1 || true
    fi
    stopped="true"
  fi

  rm -f "${PID_FILE}"

  if [[ "${stopped}" != "true" ]]; then
    if run_as_sudo pkill -f "sing-box run -c ${CONFIG_JSON}" >/dev/null 2>&1; then
      stopped="true"
    fi
  fi

  if [[ "${stopped}" == "true" ]]; then
    stdout_line "${COLOR_GREEN}" "stopped"
  else
    stdout_line "${COLOR_YELLOW}" "not running"
  fi
}

cmd_status() {
  load_env
  local pid=""
  if pid="$(read_pid_file)" && pid_is_alive "${pid}"; then
    stdout_line "${COLOR_GREEN}" "running (pid: ${pid})"
  else
    stdout_line "${COLOR_YELLOW}" "not running"
  fi
}

cmd_log() {
  load_env
  local lines="200"
  local follow="true"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n|--lines)
        shift
        [[ $# -gt 0 ]] || die "missing value for --lines"
        lines="$1"
        ;;
      --no-follow)
        follow="false"
        ;;
      *)
        die "unknown flag for log: $1"
        ;;
    esac
    shift
  done

  [[ -f "${LOG_FILE}" ]] || die "missing log file: ${LOG_FILE}"
  if is_true "${follow}"; then
    tail -n "${lines}" -f "${LOG_FILE}"
  else
    tail -n "${lines}" "${LOG_FILE}"
  fi
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "${cmd}" in
    init) init_files "$@" ;;
    check-singbox) cmd_check_singbox "$@" ;;
    install-singbox) cmd_install_singbox "$@" ;;
    install-guide) cmd_install_guide "$@" ;;
    build-rules) cmd_build_rules "$@" ;;
    build-ruleset) cmd_build_ruleset "$@" ;;
    publish-ruleset) cmd_publish_ruleset "$@" ;;
    extract) cmd_extract "$@" ;;
    build-config) cmd_build_config "$@" ;;
    pipeline) cmd_pipeline "$@" ;;
    on) cmd_on "$@" ;;
    off) cmd_off "$@" ;;
    status) cmd_status "$@" ;;
    log) cmd_log "$@" ;;
    help|-h|--help) usage ;;
    version|-v|--version)
      printf '%s\n' "${FLY_VERSION}"
      ;;
    *)
      die "unknown command: ${cmd}. Run ./fly help"
      ;;
  esac
}

main "$@"
