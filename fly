cmd_on() {
  load_env
  local config_file="${CONFIG_JSON}"
  local config_explicit="false"
  local interactive="auto"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        shift
        [[ $# -gt 0 ]] || die "missing value for --config"
        config_file="$1"
        config_explicit="true"
        ;;
      --interactive)
        interactive="true"
        ;;
      --no-interactive)
        interactive="false"
        ;;
      *)
        if [[ "$1" == -* ]]; then
          die "unknown flag for on: $1"
        fi
        if [[ "${config_explicit}" == "true" ]]; then
          die "multiple config paths specified for on"
        fi
        config_file="$1"
        config_explicit="true"
        ;;
    esac
    shift
  done

  if [[ "${interactive}" == "auto" ]]; then
    if fly_can_tui && [[ "${config_explicit}" != "true" ]]; then
      interactive="true"
    else
      interactive="false"
    fi
  fi
  if is_true "${interactive}"; then
    if fly_tui_choose_on_config "${CONFIG_OUTPUT_DIR}"; then
      config_file="${_FLY_ON_CONFIG_RESULT}"
      log "interactive selected config -> ${config_file}"
    else
      die "no selectable *.json in ${CONFIG_OUTPUT_DIR} (or cancelled by user)"
    fi
  fi

  if [[ "${config_file}" != /* ]]; then
    local raw_config="${config_file#./}"
    if [[ "${raw_config}" != */* ]] && [[ -f "${CONFIG_OUTPUT_DIR}/${raw_config}" ]]; then
      config_file="${CONFIG_OUTPUT_DIR}/${raw_config}"
    else
      config_file="$(pwd)/${raw_config}"
    fi
  fi
  [[ -f "${config_file}" ]] || die "missing config file: ${config_file}"
  need_cmd nohup
  need_cmd "${SING_BOX_BIN}"

  local old_pid=""
  if old_pid="$(read_pid_file)" && pid_is_alive "${old_pid}"; then
    stdout_line "${COLOR_YELLOW}" "already running (pid: ${old_pid})"
    return 0
  fi

  ensure_sudo_ticket
  mkdir -p "$(dirname "${PID_FILE}")" "$(dirname "${LOG_FILE}")"

  local start_cmd
  printf -v start_cmd 'nohup %q run -c %q > %q 2>&1 & echo $! > %q' \
    "${SING_BOX_BIN}" "${config_file}" "${LOG_FILE}" "${PID_FILE}"

  if [[ -n "${SUDO_BIN}" ]]; then
    "${SUDO_BIN}" sh -c "${start_cmd}"
  else
    sh -c "${start_cmd}"
  fi

  sleep 1
  local new_pid
  new_pid="$(read_pid_file || true)"
  [[ -n "${new_pid}" ]] || die "failed to write PID file: ${PID_FILE}"
  if ! pid_is_alive "${new_pid}"; then
    die "process failed to start (pid=${new_pid}); check ${LOG_FILE}"
  fi
  stdout_line "${COLOR_GREEN}" "started (pid: ${new_pid})"
  stdout_line "${COLOR_CYAN}" "config: ${config_file}"
  stdout_line "${COLOR_CYAN}" "log: ${LOG_FILE}"

  macos_dns_guard_apply_if_needed "${config_file}"
}

cmd_off() {
  load_env
  local stopped="false"
  local pid=""

  if pid="$(read_pid_file)" && pid_is_alive "${pid}"; then
    run_as_sudo kill "${pid}" >/dev/null 2>&1 || true
    local _i
    for _i in 1 2 3 4 5; do
      if ! pid_is_alive "${pid}"; then
        break
      fi
      sleep 1
    done
    if pid_is_alive "${pid}"; then
      run_as_sudo kill -9 "${pid}" >/dev/null 2>&1 || true
    fi
    stopped="true"
  fi

  rm -f "${PID_FILE}"

  if [[ "${stopped}" != "true" ]]; then
    if run_as_sudo pkill -f "sing-box run -c ${CONFIG_JSON}" >/dev/null 2>&1; then
      stopped="true"
    fi
  fi

  if [[ "${stopped}" == "true" ]]; then
    stdout_line "${COLOR_GREEN}" "stopped"
  else
    stdout_line "${COLOR_YELLOW}" "not running"
  fi

  macos_dns_guard_restore_if_needed
}

cmd_status() {
  load_env
  local pid=""
  if pid="$(read_pid_file)" && pid_is_alive "${pid}"; then
    stdout_line "${COLOR_GREEN}" "running (pid: ${pid})"
