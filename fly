#!/usr/bin/env bash
set -euo pipefail

FLY_VERSION="0.3.0"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="${ROOT_DIR}/config"
TEMPLATE_DIR="${ROOT_DIR}/config_template"
BUILD_DIR="${ROOT_DIR}/build"
STATE_DIR="${ROOT_DIR}/state"
SCRIPTS_DIR="${ROOT_DIR}/scripts"
ENV_FILE="${CONFIG_DIR}/fly.env"
ENV_EXAMPLE_FILE="${TEMPLATE_DIR}/fly.env.example"
PROVIDERS_FILE="${CONFIG_DIR}/extract.providers.json"
PROVIDERS_EXAMPLE_FILE="${TEMPLATE_DIR}/extract.providers.example.json"
RULE_SOURCES_FILE_DEFAULT="${CONFIG_DIR}/rule-sources.json"
RULE_SOURCES_EXAMPLE_FILE="${TEMPLATE_DIR}/rule-sources.example.json"
GROUP_STRATEGY_FILE_DEFAULT="${CONFIG_DIR}/group-strategy.json"
GROUP_STRATEGY_EXAMPLE_FILE="${TEMPLATE_DIR}/group-strategy.example.json"
ROUTE_RULES_FILE_DEFAULT="${CONFIG_DIR}/route-rules.json"
ROUTE_RULES_EXAMPLE_FILE="${TEMPLATE_DIR}/route-rules.example.json"

MACOS_DNS_GUARD_STATE_FILE="${STATE_DIR}/macos-dns-guard.json"

COLOR_RESET=$'\033[0m'
COLOR_BLUE=$'\033[34m'
COLOR_GREEN=$'\033[32m'
COLOR_YELLOW=$'\033[33m'
COLOR_RED=$'\033[31m'
COLOR_CYAN=$'\033[36m'
COLOR_STDOUT_ENABLED="0"
COLOR_STDERR_ENABLED="0"

if [[ -z "${NO_COLOR:-}" ]] && [[ "${TERM:-}" != "dumb" ]]; then
  if [[ -t 1 ]]; then
    COLOR_STDOUT_ENABLED="1"
  fi
  if [[ -t 2 ]]; then
    COLOR_STDERR_ENABLED="1"
  fi
fi

stdout_line() {
  local color="$1"
  local text="$2"
  if [[ "${COLOR_STDOUT_ENABLED}" == "1" ]]; then
    printf '%b%s%b\n' "${color}" "${text}" "${COLOR_RESET}"
  else
    printf '%s\n' "${text}"
  fi
}

stderr_line() {
  local color="$1"
  local text="$2"
  if [[ "${COLOR_STDERR_ENABLED}" == "1" ]]; then
    printf '%b%s%b\n' "${color}" "${text}" "${COLOR_RESET}" >&2
  else
    printf '%s\n' "${text}" >&2
  fi
}

log() {
  if [[ "${COLOR_STDOUT_ENABLED}" == "1" ]]; then
    printf '%b[fly]%b %s\n' "${COLOR_BLUE}" "${COLOR_RESET}" "$*"
  else
    printf '[fly] %s\n' "$*"
  fi
}

warn() {
  if [[ "${COLOR_STDERR_ENABLED}" == "1" ]]; then
    printf '%b[fly][warn]%b %s\n' "${COLOR_YELLOW}" "${COLOR_RESET}" "$*" >&2
  else
    printf '[fly][warn] %s\n' "$*" >&2
  fi
}

die() {
  if [[ "${COLOR_STDERR_ENABLED}" == "1" ]]; then
    printf '%b[fly][error]%b %s\n' "${COLOR_RED}" "${COLOR_RESET}" "$*" >&2
  else
    printf '[fly][error] %s\n' "$*" >&2
  fi
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

abs_path() {
  local path="$1"
  if [[ "${path}" = /* ]]; then
    printf '%s\n' "${path}"
  else
    printf '%s\n' "${ROOT_DIR}/${path#./}"
  fi
}

usage() {
  cat <<'EOF'
Fly - decoupled sing-box pipeline

Usage:
  ./fly init [--force]
  ./fly check-singbox
  ./fly install-singbox [--version v] [--os linux|darwin] [--arch amd64|arm64] [--install-dir dir] [--dry-run] [--force]
  ./fly install-guide
  ./fly build-rules [--ruleset] [--compact] [--base-url url] [--ruleset-dir dir] [--skip-compile] [--interactive]
  ./fly build-ruleset [--base-url url] [--ruleset-dir dir] [--skip-compile]  # alias of build-rules --ruleset
  ./fly publish-ruleset [--message msg] [--dry-run]
  ./fly extract
  ./fly build-config [--target desktop|ios] [--profile vt|terminal] [--ruleset] [--compact] [--interactive]
  ./fly pipeline [--target desktop|ios] [--profile vt|terminal] [--ruleset] [--compact] [--interactive]
  ./fly interactive
  ./fly menu    # alias of interactive
  ./fly on [--config path] [--interactive]
  ./fly off
  ./fly status
  ./fly log [-n lines] [--no-follow]
  ./fly select [group-name]
  ./fly delay [group-name]
  ./fly monitor
  ./fly help

Command summary:
  init          Create local runtime config files from templates
  check-singbox Show installed sing-box path and version
  install-singbox Auto download + install sing-box for linux/mac
  install-guide  Alias of install-singbox --dry-run
  build-rules   Build route rules from QX/Clash sources (inline by default; use --ruleset or --interactive for mode selection)
  build-ruleset Alias of build-rules --ruleset (kept for backward compatibility)
  publish-ruleset Stage/commit/push ruleset/ to GitHub
  extract       Extract region nodes only (US/HK/SG/JP, no route rules)
  build-config  Build final config (supports vt/terminal desktop profile + interactive mode selection)
  pipeline      Run extract + build-config (or --ruleset path), supports --profile and --interactive
  interactive   Open unified build menu (extract / build-rules / build-config / pipeline)
  menu          Alias of interactive
  on            Start sing-box in background (can interactively choose *.json in CONFIG_OUTPUT_DIR)
  off           Stop sing-box using PID file (with pkill fallback)
  status        Show running status from PID file
  log           Tail sing-box log file
  select        Live switch active node of a selector group (via Clash API, no restart)
  delay         Test latency of all nodes in a selector group (via Clash API)
  monitor       Live dashboard: traffic, group status, latency (q=quit, s=select, d=delay)
  help          Show this help
EOF
}

backup_existing_file() {
  local file="$1"
  [[ -f "${file}" ]] || return 0
  mkdir -p "${BUILD_DIR}/backup"
  local backup_file="${BUILD_DIR}/backup/$(basename "${file}").bak.$(date +%Y%m%d%H%M%S)"
  cp "${file}" "${backup_file}"
  log "backup ${file} -> ${backup_file}"
}

load_env() {
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck disable=SC1090
    source "${ENV_FILE}"
  else
    warn "missing ${ENV_FILE}; using built-in defaults (run ./fly init to generate files)"
  fi

  : "${PYTHON_BIN:=python3}"
  : "${SING_BOX_BIN:=sing-box}"
  if [[ -z "${SUDO_BIN+x}" ]]; then
    SUDO_BIN="sudo"
  fi
  : "${EXTRACT_PROVIDERS_FILE:=./config/extract.providers.json}"
  : "${RULE_SOURCES_FILE:=./config/rule-sources.json}"
  : "${GROUP_STRATEGY_FILE:=./config/group-strategy.json}"
  : "${NODES_FILE:=./build/nodes.json}"
  : "${ROUTE_RULES_FILE:=./config/route-rules.json}"
  : "${ROUTE_RULES_FILE_ONLINE:=}"
  : "${ROUTE_RULES_FILE_RULESET:=${ROUTE_RULES_FILE_ONLINE:-./config/route-rules.ruleset.json}}"
  : "${BASE_TEMPLATE_FILE:=./config/base-template.json}"
  : "${BASE_TEMPLATE_FILE_IOS:=./config/base-template.ios.json}"
  : "${BASE_TEMPLATE_FILE_TERMINAL:=./config/base-template.json}"
  : "${CONFIG_OUTPUT_DIR:=./runtime-configs}"
  : "${CONFIG_JSON:=}"
  : "${CONFIG_JSON_IOS:=}"
  : "${CONFIG_JSON_TERMINAL:=}"
  if [[ -z "${CONFIG_JSON}" || "${CONFIG_JSON}" == "./config.json" ]]; then
    CONFIG_JSON="${CONFIG_OUTPUT_DIR}/config.json"
  fi
  if [[ -z "${CONFIG_JSON_IOS}" || "${CONFIG_JSON_IOS}" == "./config.ios.json" ]]; then
    CONFIG_JSON_IOS="${CONFIG_OUTPUT_DIR}/config.ios.json"
  fi
  if [[ -z "${CONFIG_JSON_TERMINAL}" || "${CONFIG_JSON_TERMINAL}" == "./config.terminal.json" ]]; then
    CONFIG_JSON_TERMINAL="${CONFIG_OUTPUT_DIR}/config.terminal.json"
  fi
  : "${DESKTOP_PROFILE_DEFAULT:=vt}"
  : "${RULESET_BASE_URL:=}"
  : "${RULESET_DIR:=./ruleset}"
  : "${RULESET_DOWNLOAD_DETOUR:=Proxy}"
  : "${RULESET_TAG_PREFIX:=qx-}"
  : "${PID_FILE:=./.sing-box.pid}"
  : "${LOG_FILE:=./sing-box.log}"
  : "${SINGBOX_VERSION:=1.12.20}"
  : "${SINGBOX_INSTALL_DIR:=/usr/local/bin}"
  : "${SINGBOX_RELEASES_API:=https://api.github.com/repos/SagerNet/sing-box/releases}"
  : "${API_HOST:=127.0.0.1:9090}"
  : "${API_SECRET:=}"
  : "${MACOS_DNS_GUARD:=true}"

  EXTRACT_PROVIDERS_FILE="$(abs_path "${EXTRACT_PROVIDERS_FILE}")"
  RULE_SOURCES_FILE="$(abs_path "${RULE_SOURCES_FILE}")"
  GROUP_STRATEGY_FILE="$(abs_path "${GROUP_STRATEGY_FILE}")"
  NODES_FILE="$(abs_path "${NODES_FILE}")"
  ROUTE_RULES_FILE="$(abs_path "${ROUTE_RULES_FILE}")"
  ROUTE_RULES_FILE_RULESET="$(abs_path "${ROUTE_RULES_FILE_RULESET}")"
  BASE_TEMPLATE_FILE="$(abs_path "${BASE_TEMPLATE_FILE}")"
  BASE_TEMPLATE_FILE_IOS="$(abs_path "${BASE_TEMPLATE_FILE_IOS}")"
  BASE_TEMPLATE_FILE_TERMINAL="$(abs_path "${BASE_TEMPLATE_FILE_TERMINAL}")"
  CONFIG_OUTPUT_DIR="$(abs_path "${CONFIG_OUTPUT_DIR}")"
  CONFIG_JSON="$(abs_path "${CONFIG_JSON}")"
  CONFIG_JSON_IOS="$(abs_path "${CONFIG_JSON_IOS}")"
  CONFIG_JSON_TERMINAL="$(abs_path "${CONFIG_JSON_TERMINAL}")"
  RULESET_DIR="$(abs_path "${RULESET_DIR}")"
  PID_FILE="$(abs_path "${PID_FILE}")"
  LOG_FILE="$(abs_path "${LOG_FILE}")"
}

is_darwin() {
  [[ "$(uname -s)" == "Darwin" ]]
}

config_has_tun_inbound() {
  local config_file="$1"
  [[ -f "${config_file}" ]] || return 1
  "${PYTHON_BIN}" - "${config_file}" <<'PY'
import json
import sys
from pathlib import Path

cfg = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
inbounds = cfg.get("inbounds", [])
has_tun = any(isinstance(item, dict) and item.get("type") == "tun" for item in inbounds)
raise SystemExit(0 if has_tun else 1)
PY
}

macos_get_default_interface() {
  route -n get default 2>/dev/null | awk '/interface:/{print $2; exit}'
}

macos_find_network_service_for_device() {
  local device="$1"
  command -v networksetup >/dev/null 2>&1 || return 1
  local current=""
  while IFS= read -r line; do
    if [[ "${line}" == "("*") "* ]]; then
      current="${line#*) }"
      current="${current#\*}"
      current="${current#"${current%%[![:space:]]*}"}"
      continue
    fi
    if [[ -n "${current}" && "${line}" == *"Device: ${device}"* ]]; then
      printf '%s\n' "${current}"
      return 0
    fi
  done < <(networksetup -listnetworkserviceorder 2>/dev/null || true)
  return 1
}

macos_get_primary_network_service() {
  command -v networksetup >/dev/null 2>&1 || return 1

  local -a services=()
  local current=""
  while IFS= read -r line; do
    if [[ "${line}" == "("*") "* ]]; then
      current="${line#*) }"
      current="${current#\*}"
      current="$(printf '%s' "${current}" | xargs || true)"
      [[ -n "${current}" ]] || continue
      services+=("${current}")
    fi
  done < <(networksetup -listnetworkserviceorder 2>/dev/null || true)

  local service info ipv4 ipv6
  for service in "${services[@]}"; do
    info="$(networksetup -getinfo "${service}" 2>/dev/null || true)"
    ipv4="$(printf '%s\n' "${info}" | awk -F': ' '/^IP address:/{print $2; exit}' | xargs || true)"
    ipv6="$(printf '%s\n' "${info}" | awk -F': ' '/^IPv6 IP address:/{print $2; exit}' | xargs || true)"
    if [[ -n "${ipv4}" && "${ipv4}" != "none" && "${ipv4}" != "0.0.0.0" ]]; then
      printf '%s\n' "${service}"
      return 0
    fi
    if [[ -n "${ipv6}" && "${ipv6}" != "none" ]]; then
      printf '%s\n' "${service}"
      return 0
    fi
  done

  # Fallback: pick the first service in order.
  if ((${#services[@]})); then
    printf '%s\n' "${services[0]}"
    return 0
  fi
  return 1
}

macos_dns_guard_write_state() {
  local service="$1"
  local mode="$2"
  shift 2
  mkdir -p "${STATE_DIR}"
  "${PYTHON_BIN}" - "${service}" "${mode}" "$@" <<'PY' > "${MACOS_DNS_GUARD_STATE_FILE}"
import json
import sys

service = sys.argv[1]
mode = sys.argv[2]
servers = sys.argv[3:]

print(
    json.dumps(
        {
            "service": service,
            "mode": mode,
            "servers": servers,
        },
        ensure_ascii=False,
        indent=2,
    )
)
PY
}

macos_dns_guard_apply_if_needed() {
  local config_file="$1"
  is_darwin || return 0
  is_true "${MACOS_DNS_GUARD}" || return 0
  command -v networksetup >/dev/null 2>&1 || return 0

  if [[ -z "${SUDO_BIN}" ]]; then
    warn "MACOS_DNS_GUARD is enabled but SUDO_BIN is empty; skip applying DNS guard"
    return 0
  fi

  config_has_tun_inbound "${config_file}" || return 0

  if [[ -f "${MACOS_DNS_GUARD_STATE_FILE}" ]]; then
    return 0
  fi

  local device=""
  device="$(macos_get_default_interface || true)"
  local service=""
  if [[ -n "${device}" && "${device}" != utun* ]]; then
    service="$(macos_find_network_service_for_device "${device}" || true)"
  fi
  if [[ -z "${service}" ]]; then
    service="$(macos_get_primary_network_service || true)"
  fi
  if [[ -z "${service}" ]]; then
    warn "cannot detect a network service for macOS DNS guard; skip"
    return 0
  fi

  local raw=""
  raw="$(networksetup -getdnsservers "${service}" 2>/dev/null || true)"
  local mode="list"
  local -a servers=()
  if printf '%s\n' "${raw}" | grep -q "There aren't any DNS Servers set"; then
    mode="empty"
  else
    while IFS= read -r line; do
      line="$(printf '%s' "${line}" | xargs || true)"
      [[ -n "${line}" ]] || continue
      servers+=("${line}")
    done <<< "${raw}"
  fi

  if [[ "${mode}" == "empty" ]]; then
    macos_dns_guard_write_state "${service}" "empty"
  else
    macos_dns_guard_write_state "${service}" "list" "${servers[@]}"
  fi

  # Force system DNS to public resolvers while sing-box is running.
  # This prevents common macOS DNS leak scenarios when the system DNS comes from LAN/router (private IP),
  # which may bypass tun routes due to more specific local routes.
  if ! run_as_sudo networksetup -setdnsservers "${service}" 223.5.5.5 223.6.6.6 2400:3200::1 2400:3200:baba::1 >/dev/null 2>&1; then
    # Some setups reject IPv6 resolvers (or have IPv6 disabled). Fall back to IPv4-only guard
    # instead of skipping the guard entirely.
    if ! run_as_sudo networksetup -setdnsservers "${service}" 223.5.5.5 223.6.6.6 >/dev/null 2>&1; then
      warn "failed to apply macOS DNS guard via networksetup; skip"
      rm -f "${MACOS_DNS_GUARD_STATE_FILE}" || true
      return 0
    fi
  fi
  run_as_sudo dscacheutil -flushcache >/dev/null 2>&1 || true
  run_as_sudo killall -HUP mDNSResponder >/dev/null 2>&1 || true

  if [[ -t 1 ]]; then
    log "macOS DNS guard applied for '${service}' (restored on ./fly off)"
  fi
}

macos_dns_guard_restore_if_needed() {
  is_darwin || return 0
  command -v networksetup >/dev/null 2>&1 || return 0
  [[ -f "${MACOS_DNS_GUARD_STATE_FILE}" ]] || return 0
  [[ -n "${SUDO_BIN}" ]] || return 0

  local info=""
  info="$("${PYTHON_BIN}" - "${MACOS_DNS_GUARD_STATE_FILE}" <<'PY'
import json
import sys
from pathlib import Path

d = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
print(d.get("service", ""))
print(d.get("mode", ""))
for s in d.get("servers", []):
    print(s)
PY
)" || return 0

  local service mode
  service="$(printf '%s\n' "${info}" | sed -n '1p')"
  mode="$(printf '%s\n' "${info}" | sed -n '2p')"
  if [[ -z "${service}" ]]; then
    rm -f "${MACOS_DNS_GUARD_STATE_FILE}" || true
    return 0
  fi

  if [[ "${mode}" == "empty" ]]; then
    run_as_sudo networksetup -setdnsservers "${service}" empty >/dev/null 2>&1 || true
  else
    local -a servers=()
    while IFS= read -r line; do
      [[ -n "${line}" ]] || continue
      servers+=("${line}")
    done < <(printf '%s\n' "${info}" | sed -n '3,$p')
    if ((${#servers[@]})); then
      run_as_sudo networksetup -setdnsservers "${service}" "${servers[@]}" >/dev/null 2>&1 || true
    else
      run_as_sudo networksetup -setdnsservers "${service}" empty >/dev/null 2>&1 || true
    fi
  fi

  rm -f "${MACOS_DNS_GUARD_STATE_FILE}" || true
  run_as_sudo dscacheutil -flushcache >/dev/null 2>&1 || true
  run_as_sudo killall -HUP mDNSResponder >/dev/null 2>&1 || true
  if [[ -t 1 ]]; then
    log "macOS DNS guard restored for '${service}'"
  fi
}

detect_os() {
  case "$(uname -s)" in
    Linux) printf 'linux\n' ;;
    Darwin) printf 'darwin\n' ;;
    *) die "unsupported OS: $(uname -s)" ;;
  esac
}

detect_arch() {
  case "$(uname -m)" in
    x86_64|amd64) printf 'amd64\n' ;;
    aarch64|arm64) printf 'arm64\n' ;;
    *) die "unsupported architecture: $(uname -m)" ;;
  esac
}

# ---------------------------------------------------------------------------
# Clash API helpers
# ---------------------------------------------------------------------------

# Globals set by fly_api() after each call
FLY_API_HTTP_CODE=""
FLY_API_BODY=""

# fly_api METHOD PATH [BODY_JSON]
# Sets FLY_API_HTTP_CODE and FLY_API_BODY globals. Never call via $().
fly_api() {
  local method="$1"
  local path="$2"
  local body="${3:-}"

  local curl_args=(-s --connect-timeout 5 -X "${method}")
  [[ -n "${API_SECRET:-}" ]] && curl_args+=(-H "Authorization: Bearer ${API_SECRET}")
  [[ -n "${body}" ]] && curl_args+=(-H "Content-Type: application/json" -d "${body}")

  local tmp
  tmp="$(mktemp)"
  FLY_API_HTTP_CODE="$(curl "${curl_args[@]}" -w '%{http_code}' -o "${tmp}" \
    "http://${API_HOST}${path}" 2>/dev/null)" || FLY_API_HTTP_CODE="000"
  FLY_API_BODY="$(cat "${tmp}")"
  rm -f "${tmp}"
}

# Returns 0 if the Clash API is reachable, 1 otherwise.
fly_api_check() {
  command -v curl >/dev/null 2>&1 || return 1
  local code
  code="$(curl -s -o /dev/null -w '%{http_code}' --connect-timeout 2 \
    "http://${API_HOST}/version" 2>/dev/null)" || code="000"
  [[ "${code}" =~ ^2 ]]
}

# ---------------------------------------------------------------------------
# TUI helpers (Tide-style: numbered key selection)
# ---------------------------------------------------------------------------

_FLY_TUI_SYMS=()
_FLY_TUI_LABELS=()
_FLY_TUI_RESULT=""

_fly_tui_reset() {
  _FLY_TUI_SYMS=()
  _FLY_TUI_LABELS=()
}

_fly_tui_title() {
  clear
  if [[ "${COLOR_STDOUT_ENABLED}" == "1" ]]; then
    printf '\033[1;36m=== %s ===\033[0m\n\n' "$1"
  else
    printf '=== %s ===\n\n' "$1"
  fi
}

# _fly_tui_option SYM LABEL [META]
_fly_tui_option() {
  local sym="$1" label="$2" meta="${3:-}"
  _FLY_TUI_SYMS+=("${sym}")
  _FLY_TUI_LABELS+=("${label}")
  if [[ "${COLOR_STDOUT_ENABLED}" == "1" ]]; then
    if [[ -n "${meta}" ]]; then
      printf '  \033[36m(%s)\033[0m %-28s \033[33m%s\033[0m\n' "${sym}" "${label}" "${meta}"
    else
      printf '  \033[36m(%s)\033[0m %s\n' "${sym}" "${label}"
    fi
  else
    if [[ -n "${meta}" ]]; then
      printf '  (%s) %-28s %s\n' "${sym}" "${label}" "${meta}"
    else
      printf '  (%s) %s\n' "${sym}" "${label}"
    fi
  fi
}

# Wait for a key matching one of the registered symbols.
# Sets _FLY_TUI_RESULT to the selected symbol, or "q" to quit.
_fly_tui_prompt() {
  local hint="${1:-选择}"
  local syms_copy=("${_FLY_TUI_SYMS[@]}")
  local syms_str
  # shellcheck disable=SC2124
  syms_str="$(
    local IFS='/'
    echo "${syms_copy[*]}"
  )"
  printf '\n%s [%s/q]: ' "${hint}" "${syms_str}"
  local key
  while IFS= read -rsn1 key; do
    if [[ "${key}" == "q" || "${key}" == "Q" ]]; then
      printf '\n'
      _FLY_TUI_RESULT="q"
      _fly_tui_reset
      return 0
    fi
    local sym
    for sym in "${syms_copy[@]}"; do
      if [[ "${key}" == "${sym}" ]]; then
        printf '\n'
        _FLY_TUI_RESULT="${sym}"
        _fly_tui_reset
        return 0
      fi
    done
  done
}

fly_tui_symbol_for_index() {
  local idx="${1:-0}"
  local symbols="123456789abcdefghijklmnopqrstuvwxyz"
  if ((idx < 0)); then
    return 1
  fi
  if ((idx >= ${#symbols})); then
    return 1
  fi
  printf '%s\n' "${symbols:${idx}:1}"
}

fly_can_tui() {
  [[ -t 0 && -t 1 ]]
}

get_terminal_core_version_hint() {
  local info=""
  info="$(get_singbox_installed_info || true)"
  if [[ -n "${info}" ]]; then
    local installed_norm
    installed_norm="$(printf '%s\n' "${info}" | sed -n '3p')"
    if [[ -n "${installed_norm}" ]]; then
      printf '%s\n' "${installed_norm}"
      return 0
    fi
  fi
  local fallback
  fallback="$(normalize_version "${SINGBOX_VERSION}")"
  if [[ -n "${fallback}" ]]; then
    printf '%s\n' "${fallback}"
  else
    printf '%s\n' "1.12+"
  fi
}

_FLY_BUILD_TARGET="desktop"
_FLY_BUILD_RULESET="false"
_FLY_BUILD_PROFILE="vt"

fly_tui_choose_build_mode() {
  local target_default="${1:-desktop}"
  local ruleset_default="${2:-false}"
  local profile_default="${3:-vt}"

  _FLY_BUILD_TARGET="${target_default}"
  _FLY_BUILD_RULESET="${ruleset_default}"
  _FLY_BUILD_PROFILE="${profile_default}"

  _fly_tui_title "配置生成向导 · 第1步 选择平台"
  _fly_tui_option "1" "iOS（VT 1.11.4）" ""
  _fly_tui_option "2" "电脑端" ""
  _fly_tui_prompt "选择平台"
  local selected="${_FLY_TUI_RESULT}"
  [[ "${selected}" == "q" ]] && return 1
  if [[ "${selected}" == "1" ]]; then
    _FLY_BUILD_TARGET="ios"
    _FLY_BUILD_PROFILE="vt"
  else
    _FLY_BUILD_TARGET="desktop"
  fi

  _fly_tui_title "配置生成向导 · 第2步 Rule Set 模式"
  _fly_tui_option "1" "有 Rule Set（远程 .srs）" "更小配置"
  _fly_tui_option "2" "无 Rule Set（内联规则）" "直观可读"
  _fly_tui_prompt "选择规则模式"
